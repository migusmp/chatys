{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            m.id,\n            m.sender_id,\n            u.username,\n            m.content,\n            m.created_at,\n            m.read_by,\n            m.edited_at,\n            m.is_deleted\n        FROM messages m\n        JOIN users u ON u.id = m.sender_id\n        WHERE m.conversation_id = $1\n          AND ($2::int IS NULL OR m.id < $2)\n        ORDER BY m.id DESC\n        LIMIT $3\n        ",
