{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            c.id AS conversation_id,\n            c.created_at,\n            c.updated_at,\n            c.is_group,\n            u.id AS user_id,\n            u.username,\n            u.image\n        FROM conversations c\n        JOIN conversation_participants cp ON c.id = cp.conversation_id\n        JOIN users u ON cp.user_id = u.id\n        WHERE c.id = $1\n        ",
