{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            mr.message_id,\n            mr.user_id,\n            u.username,\n            mr.emoji\n        FROM message_reactions mr\n        JOIN users u ON u.id = mr.user_id\n        WHERE mr.message_id = ANY($1)\n        ORDER BY mr.message_id, mr.emoji, mr.created_at\n        ",
